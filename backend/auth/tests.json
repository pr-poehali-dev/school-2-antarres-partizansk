{
  "tests": [
    {
      "name": "Register student",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Тест Ученик", "email": "test_xyz_99@test.com", "password": "123456", "role": "student", "class_name": "6А"},
      "expectedStatus": 201,
      "expectedBody": {"status": "pending"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_xyz_99@test.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login pending user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_xyz_99@test.com", "password": "123456"},
      "expectedStatus": 403,
      "expectedBody": {"error": "Ваша заявка ещё не одобрена администратором"},
      "bodyMatcher": "partial"
    }
  ]
}
